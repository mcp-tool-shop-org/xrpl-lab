---
import '../styles/global.css';
import '../styles/dashboard-fonts.css';
import '../styles/dashboard.css';

interface Props {
  title: string;
  activePage?: string;
}

const { title, activePage = '' } = Astro.props;
const base = '/xrpl-lab';

// SVG icons for the server-rendered sidebar nav (mirrors src/lib/dashboard-ui.ts).
const ic = {
  dash: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg>',
  book: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h11a3 3 0 0 1 3 3v13H8a3 3 0 0 1-3-3z"/><path d="M5 17a3 3 0 0 1 3-3h11"/></svg>',
  seal: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 4v5c0 4.4-3 7.6-7 9-4-1.4-7-4.6-7-9V7z"/><path d="M9 12l2 2 4-4"/></svg>',
  doctor: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v5a4 4 0 0 0 8 0V3"/><path d="M10 16a5 5 0 0 0 10 0v-2"/><circle cx="20" cy="11" r="2"/></svg>',
  board: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h16M4 12h16M4 19h16"/><circle cx="8" cy="5" r="1.6" fill="currentColor" stroke="none"/><circle cx="15" cy="12" r="1.6" fill="currentColor" stroke="none"/><circle cx="11" cy="19" r="1.6" fill="currentColor" stroke="none"/></svg>',
  menu: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>',
};

const workbook = [
  { href: `${base}/app/`, label: 'Dashboard', id: 'dashboard', icon: ic.dash },
  { href: `${base}/app/modules/`, label: 'Modules', id: 'modules', icon: ic.book },
  { href: `${base}/app/artifacts/`, label: 'Artifacts', id: 'artifacts', icon: ic.seal },
  { href: `${base}/app/doctor/`, label: 'Doctor', id: 'doctor', icon: ic.doctor },
];
// F-FE-FT-001: facilitator surface — monitor concurrent learner runs.
const facilitator = [
  { href: `${base}/app/facilitator/runs/`, label: 'Runs', id: 'facilitator', icon: ic.board },
];
---

<!doctype html>
<html lang="en" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} - XRPL Lab</title>
  <meta name="description" content="XRPL Lab — learn by doing, prove by artifact. Testnet-only XRP Ledger training workbook." />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
</head>
<body>
  <div class="app" id="app" data-nav-open="false">
    <div class="scrim" id="scrim"></div>

    <!-- ============ SIDEBAR ============ -->
    <aside class="sidebar" id="sidebar" aria-label="Primary">
      <a class="brand" href={`${base}/app/`}>
        <span class="brand__badge" aria-hidden="true">XL</span>
        <span class="stack"><span class="brand__name">XRPL Lab</span><span class="brand__tag">learn by doing, prove by artifact.</span></span>
      </a>
      <nav class="nav" aria-label="Sections">
        <span class="nav__label">Workbook</span>
        {workbook.map((l) => (
          <a class="navlink" href={l.href} aria-current={activePage === l.id ? 'page' : 'false'}>
            <Fragment set:html={l.icon} /> {l.label}
          </a>
        ))}
        <span class="nav__label">Facilitator</span>
        {facilitator.map((l) => (
          <a class="navlink" href={l.href} aria-current={activePage === l.id ? 'page' : 'false'}>
            <Fragment set:html={l.icon} /> {l.label}
          </a>
        ))}
      </nav>
      <div class="sidebar__foot">
        <span class="netpill" id="netpill">
          <span class="statdot statdot--ok" id="netpill-dot"></span> <span id="netpill-text">Connecting…</span>
        </span>
        <div style="display:flex;gap:14px;flex-wrap:wrap;">
          <a href={`${base}/`} class="sidebar__ver" style="color:var(--text-2)">Home</a>
          <a href={`${base}/handbook/`} class="sidebar__ver" style="color:var(--text-2)">Handbook</a>
        </div>
        <span class="sidebar__ver" id="sidebar-ver">XRPL Lab · v… · MIT</span>
      </div>
    </aside>

    <!-- ============ MAIN ============ -->
    <div class="stack" style="min-width:0">
      <button class="nav-toggle" id="navToggle" aria-label="Open navigation" aria-controls="sidebar">
        <Fragment set:html={ic.menu} /><span>Menu</span>
      </button>
      <main class="main" id="main">
        <slot />
      </main>
    </div>
  </div>

  <!-- branded modal mount + screen-reader live region -->
  <div id="modal-root"></div>
  <div id="announcer" class="sr-only" role="status" aria-live="polite"></div>

  <script>
    import { fetchWithTimeout } from '../lib/api';
    import { esc } from '../lib/dashboard-ui';

    const API_BASE = 'http://localhost:8321';

    // Mobile nav drawer
    const app = document.getElementById('app');
    document.getElementById('navToggle')?.addEventListener('click', () => {
      app?.setAttribute('data-nav-open', app.getAttribute('data-nav-open') === 'true' ? 'false' : 'true');
    });
    document.getElementById('scrim')?.addEventListener('click', () => app?.setAttribute('data-nav-open', 'false'));

    // Live connection pill + footer version from /api/status
    (async () => {
      const dot = document.getElementById('netpill-dot');
      const text = document.getElementById('netpill-text');
      const ver = document.getElementById('sidebar-ver');
      try {
        const res = await fetchWithTimeout(`${API_BASE}/api/status`);
        if (!res.ok) throw new Error(`API returned ${res.status}: ${res.statusText}`);
        const s = await res.json();
        // FRONTEND-A-004: escape the network value before interpolating into
        // innerHTML. Safe today (network is a server enum) but escaping closes
        // the latent XSS if the source ever changes — matches every other
        // network-data sink in the dashboard.
        if (text) text.innerHTML = `Connected · <span class="mono">${esc(s.network ?? 'testnet')}</span>`;
        if (dot) { dot.classList.remove('statdot--warn', 'statdot--err'); dot.classList.add('statdot--ok'); }
        if (ver && s.version) ver.textContent = `XRPL Lab · v${s.version} · MIT`;
      } catch {
        if (text) text.textContent = 'API offline — run xrpl-lab serve';
        if (dot) { dot.classList.remove('statdot--ok'); dot.classList.add('statdot--err'); }
      }
    })();
  </script>
</body>
</html>
