---
import '../styles/global.css';

interface Props {
  title: string;
  activePage?: string;
}

const { title, activePage = '' } = Astro.props;
const base = '/xrpl-lab';

const navLinks = [
  { href: `${base}/app/`, label: 'Dashboard', id: 'dashboard' },
  { href: `${base}/app/modules/`, label: 'Modules', id: 'modules' },
  { href: `${base}/app/artifacts/`, label: 'Artifacts', id: 'artifacts' },
];
---

<!doctype html>
<html lang="en" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} - XRPL Lab</title>
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
</head>
<body class="bg-slate-900 text-slate-200 min-h-screen flex flex-col">

  <!-- Header -->
  <header class="bg-slate-800 border-b border-slate-700 sticky top-0 z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <a href={`${base}/app/`} class="flex items-center gap-2 text-slate-100 font-bold text-lg hover:text-emerald-400 transition-colors">
        <span class="bg-emerald-500 text-slate-900 text-xs font-bold px-1.5 py-0.5 rounded">XL</span>
        XRPL Lab
      </a>

      <nav class="flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`px-3 py-1.5 text-sm rounded transition-colors ${
              activePage === link.id
                ? 'bg-slate-700 text-emerald-400'
                : 'text-slate-400 hover:text-slate-200 hover:bg-slate-700/50'
            }`}
          >
            {link.label}
          </a>
        ))}
        <span class="w-px h-5 bg-slate-700 mx-2"></span>
        <a
          href={`${base}/`}
          class="text-sm text-slate-500 hover:text-slate-300 transition-colors"
        >
          Home
        </a>
        <a
          href={`${base}/handbook/`}
          class="text-sm text-slate-500 hover:text-slate-300 transition-colors ml-2"
        >
          Handbook
        </a>
      </nav>
    </div>
  </header>

  <!-- Body -->
  <div class="flex-1 flex max-w-7xl mx-auto w-full">

    <!-- Sidebar -->
    <aside class="hidden lg:block w-56 shrink-0 border-r border-slate-700 p-4 overflow-y-auto">
      <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Modules</h2>
      <ul id="sidebar-modules" class="space-y-1">
        <li class="text-sm text-slate-600 animate-pulse">Loading...</li>
      </ul>
    </aside>

    <!-- Main -->
    <main class="flex-1 p-6 overflow-y-auto">
      <slot />
    </main>
  </div>

  <!-- Footer -->
  <footer class="border-t border-slate-700 py-3 px-6 text-center">
    <p class="text-xs text-slate-600">
      XRPL Lab &middot; <span id="footer-version">v-.-.-</span> &middot;
      MIT Licensed &middot;
      <a href="https://mcp-tool-shop.github.io/" class="text-slate-500 hover:text-emerald-400 transition-colors">MCP Tool Shop</a>
    </p>
  </footer>

  <!-- Sidebar + footer hydration -->
  <script>
    const API_BASE = 'http://localhost:8321';

    async function hydrateLayout() {
      // Sidebar modules
      try {
        const modules = await fetch(`${API_BASE}/api/modules`).then(r => r.json());
        const list = document.getElementById('sidebar-modules');
        if (list && Array.isArray(modules)) {
          list.innerHTML = modules.map((m: any) => {
            const dot = m.completed
              ? '<span class="text-emerald-500 mr-1.5">&#9679;</span>'
              : '<span class="text-slate-600 mr-1.5">&#9675;</span>';
            return `<li>
              <a href="/xrpl-lab/app/modules/${m.id}/"
                 class="flex items-center text-sm text-slate-400 hover:text-emerald-400 py-1 transition-colors">
                ${dot}${m.title}
              </a>
            </li>`;
          }).join('');
        }
      } catch {
        const list = document.getElementById('sidebar-modules');
        if (list) list.innerHTML = '<li class="text-sm text-slate-600">API offline</li>';
      }

      // Footer version
      try {
        const status = await fetch(`${API_BASE}/api/status`).then(r => r.json());
        const el = document.getElementById('footer-version');
        if (el && status.version) el.textContent = `v${status.version}`;
      } catch {
        // leave placeholder
      }
    }

    hydrateLayout();
  </script>
</body>
</html>
