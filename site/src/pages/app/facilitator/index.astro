---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { icons } from '../../../lib/dashboard-ui';
// Static page — no fetch. Surfaces grid is a single quick-action tile today;
// cohort views are planned for a future release (note kept as muted text below).
---

<DashboardLayout title="Facilitator" activePage="facilitator">
  <div class="screen-head">
    <h1>Facilitator</h1>
    <p class="lede">Workshop monitoring surfaces.</p>
  </div>

  <div class="screen-inner">
    <!-- Surfaces grid (single tile today; cohort views planned for a future release) -->
    <section class="grid grid-2">
      <a class="qa" href="/xrpl-lab/app/facilitator/runs/">
        <span class="qa__ic" set:html={icons.board} />
        <span class="qa__t">Active runs</span>
        <span class="qa__s">Monitor concurrent learner module runs in real time, auto-refreshes every 5s</span>
      </a>
    </section>

    <p class="muted section" style="font-size:13px">
      More facilitator views (cohort progress, live stuck-learner alerts) are planned for a future release.
    </p>
  </div>
</DashboardLayout>
