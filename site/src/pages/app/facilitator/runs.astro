---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<!--
  F-FE-FT-001: Facilitator-runs page (Stage D reskin)
  ---------------------------------------------------
  Workshop facilitators monitor 4-8 concurrent learner module runs in real
  time. Consumes GET /api/runs and DELETE /api/runs/{run_id}. Reskinned to the
  "calm instrument panel" design system; the native confirm()/alert() kill
  dialog is now the branded, focus-trapped openModal() (accessible alertdialog).
  Preserved: 5s auto-refresh, pause-when-hidden, before-swap cleanup, the
  icon+colour+TEXT status badges (no colour-only signal), and the humanized
  error copy.
-->

<DashboardLayout title="Active Runs" activePage="facilitator">
  <div class="screen-head">
    <h1>Active runs</h1>
    <p class="lede">A live board of every learner session in the room.</p>
  </div>

  <div class="screen-inner" id="fac-root">
    <div class="skeleton" style="height:78px"></div>
    <div style="height:16px"></div>
    <div class="skeleton" style="height:60px;margin-bottom:10px"></div>
    <div class="skeleton" style="height:60px"></div>
  </div>

  <script>
    import { fetchWithTimeout } from '../../../lib/api';
    import { icons, runBadge, openModal, announce, esc, fmtElapsed, fmtClock } from '../../../lib/dashboard-ui';

    const API_BASE = 'http://localhost:8321';
    const POLL_INTERVAL_MS = 5000;

    interface RunInfo {
      run_id: string; module_id: string; status: string;
      created_at: string; elapsed_seconds: number; queue_size: number; dry_run: boolean;
    }
    interface RunListResponse { runs: RunInfo[]; max_concurrent: number; active_count: number; }

    const root = document.getElementById('fac-root')!;

    // ── render: capacity meter + board ──────────────────────────────────
    function render(data: RunListResponse) {
      const active = data.active_count ?? 0;
      const max = data.max_concurrent ?? 0;
      const slots = Array.from({ length: max }, (_, i) =>
        `<span class="slot ${i < active ? 'slot--on' : ''}"></span>`).join('');

      const board = (!data.runs || data.runs.length === 0)
        ? `<div class="card"><div class="empty"><span class="empty__ic">${icons.inbox}</span>
             <div class="empty__t">No active runs</div>
             <div>When learners start modules, their sessions appear here in real time.</div></div></div>`
        : `<div class="board" role="region" aria-label="Active learner runs" aria-live="polite">
             <div class="board__head"><span>Module · run</span><span>Status</span><span>Elapsed</span><span>Queue</span><span></span></div>
             <div id="rows">${data.runs.map(runRow).join('')}</div>
           </div>`;

      root.innerHTML = `
        <div class="capbar" role="status" aria-live="polite" aria-label="Capacity: ${active} of ${max} slots active">
          <div class="cap__meter">
            <div class="cap__big"><b>${active}</b> / ${max} <small>active</small></div>
            <div class="cap__slots" aria-hidden="true">${slots}</div>
          </div>
          <span class="cap__poll" id="pollInd"><span class="statdot"></span><span id="pollText">Live · refreshing every 5s</span></span>
        </div>
        ${board}`;

      // Re-bind kill handlers + reflect poll state after each render.
      root.querySelectorAll<HTMLButtonElement>('.kill-btn').forEach((b) => b.addEventListener('click', onKillClick));
      reflectPoll();
    }

    function runRow(r: RunInfo): string {
      const killable = r.status === 'running';
      const dry = r.dry_run ? '<span class="chip chip--dry">dry-run</span>' : '';
      const queue = r.queue_size > 0 ? `<b>${r.queue_size}</b> queued` : '<span class="faint">—</span>';
      const kill = killable
        ? `<button class="btn btn--danger btn--sm kill-btn" data-id="${esc(r.run_id)}" data-mod="${esc(r.module_id)}" aria-label="Kill run ${esc(r.run_id)} (${esc(r.module_id)})">${icons.ban}<span>Kill</span></button>`
        : '';
      return `<div class="runrow" data-status="${esc(r.status)}" data-id="${esc(r.run_id)}">
        <div class="runrow__mod">
          <span class="runrow__modname" title="${esc(r.module_id)}">${esc(r.module_id)}</span>
          <span class="runrow__sub"><span class="runrow__id">${esc(r.run_id)}</span>${dry}<span class="runrow__id" title="created_at">started ${esc(fmtClock(r.created_at))}</span></span>
        </div>
        <div class="runrow__status">${runBadge(r.status)}</div>
        <div class="runrow__metric" data-elapsed><b>${esc(fmtElapsed(r.elapsed_seconds))}</b></div>
        <div class="queue">${queue}</div>
        <div class="runrow__act">${kill}</div>
      </div>`;
    }

    // ── kill flow: branded modal replaces native confirm()/alert() ──────
    function onKillClick(ev: Event) {
      const btn = ev.currentTarget as HTMLButtonElement;
      const runId = btn.dataset.id || '';
      const moduleId = btn.dataset.mod || '';
      if (!runId) return;
      openModal({
        variant: 'danger', icon: icons.ban, returnTo: btn,
        title: 'Kill this run?',
        body: `This cancels run <code class="mono">${esc(runId)}</code> (<code class="mono">${esc(moduleId)}</code>) and ends the learner's session immediately. <span class="mono faint">DELETE /api/runs/${esc(runId)}</span>`,
        confirmLabel: 'Kill run', cancelLabel: 'Keep running',
        onConfirm: () => doKill(runId, moduleId, btn),
      });
    }

    function resetKill(btn: HTMLButtonElement) {
      btn.disabled = false;
      btn.innerHTML = `${icons.ban}<span>Kill</span>`;
    }
    function errModal(title: string, body: string) {
      openModal({ variant: 'error', icon: icons.alert, title, body, confirmLabel: 'OK', cancelLabel: 'Dismiss', onConfirm: () => {} });
    }

    async function doKill(runId: string, moduleId: string, btn: HTMLButtonElement) {
      btn.disabled = true;
      btn.innerHTML = '<span class="mono">Cancelling…</span>';
      try {
        const res = await fetchWithTimeout(`${API_BASE}/api/runs/${encodeURIComponent(runId)}`, { method: 'DELETE' });
        if (res.ok) {
          announce(`Run ${moduleId} cancelled.`);
          await refresh();
        } else if (res.status === 404) {
          // Pre-DELETE state — endpoint not shipped, or the run already finished.
          resetKill(btn);
          errModal('Cancel not available', 'Either the run already finished, or the cancel endpoint is not available on this API. Refresh to see the latest state.');
        } else {
          resetKill(btn);
          errModal('Cancel failed', `HTTP ${res.status} ${esc(res.statusText)}.`);
        }
      } catch (err: any) {
        resetKill(btn);
        const msg = err?.name === 'AbortError'
          ? 'Cancel request timed out. The API may be slow or restarting.'
          : 'API is offline. Run xrpl-lab serve in a terminal, then try again.';
        errModal('Could not cancel', msg);
      }
    }

    // ── error / offline state ───────────────────────────────────────────
    function showError(err: any) {
      const timeout = err?.name === 'AbortError';
      const msg = timeout
        ? 'Request timed out. The API may be slow or restarting. Auto-refresh will retry shortly.'
        : 'API is offline. Run <code class="mono">xrpl-lab serve</code> in a terminal, then refresh.';
      root.innerHTML = `<div class="card"><div class="empty"><span class="empty__ic">${icons.alert}</span>
        <div class="empty__t">Can't reach the API</div><div>${msg}</div></div></div>`;
    }

    async function refresh() {
      try {
        const res = await fetchWithTimeout(`${API_BASE}/api/runs`);
        if (!res.ok) throw new Error(`API returned ${res.status}: ${res.statusText}`);
        render((await res.json()) as RunListResponse);
      } catch (err) {
        showError(err);
      }
    }

    // ── polling cadence (pause when tab hidden) ─────────────────────────
    let timer: number | null = null;
    function reflectPoll() {
      const t = document.getElementById('pollText');
      if (t) t.textContent = document.hidden ? 'Paused — tab hidden' : 'Live · refreshing every 5s';
      const ind = document.getElementById('pollInd');
      if (ind) ind.setAttribute('data-paused', String(document.hidden));
    }
    function startPolling() {
      if (timer !== null) return;
      timer = window.setInterval(() => { if (document.visibilityState === 'visible') refresh(); }, POLL_INTERVAL_MS);
    }
    function stopPolling() { if (timer !== null) { window.clearInterval(timer); timer = null; } }

    const visibilityHandler = () => {
      if (document.visibilityState === 'visible') { refresh(); startPolling(); }
      else { stopPolling(); reflectPoll(); }
    };
    const beforeunloadHandler = stopPolling;

    document.addEventListener('visibilitychange', visibilityHandler);
    window.addEventListener('beforeunload', beforeunloadHandler);

    // Astro client-side nav cleanup — remove listeners + clear interval so a
    // return visit starts fresh (facilitators leave this tab open for hours).
    document.addEventListener('astro:before-swap', () => {
      document.removeEventListener('visibilitychange', visibilityHandler);
      window.removeEventListener('beforeunload', beforeunloadHandler);
      stopPolling();
    }, { once: true });

    refresh();
    startPolling();
  </script>
</DashboardLayout>
