---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Page Not Found">

  <div class="flex flex-col items-center justify-center min-h-[50vh] text-center space-y-6 py-16">

    <div class="text-6xl font-black text-slate-700">404</div>

    <div>
      <h1 class="text-2xl font-bold text-slate-100 mb-2">Page not found</h1>
      <p class="text-slate-400 max-w-sm">
        This dashboard page does not exist. It may have been moved or the URL is incorrect.
      </p>
    </div>

    <a
      href="/xrpl-lab/app/"
      class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500 hover:bg-emerald-400 text-slate-900 font-semibold text-sm rounded transition-colors"
    >
      <span>&#8592;</span>
      Back to Dashboard
    </a>

  </div>

</DashboardLayout>
