---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

export function getStaticPaths() {
  const moduleIds = [
    'receipt_literacy',
    'failure_literacy',
    'trust_lines_101',
    'trust_line_failures',
    'dex_literacy',
    'reserves_101',
    'account_hygiene',
    'receipt_audit',
    'amm_liquidity_101',
    'dex_market_making_101',
    'dex_inventory_guardrails',
    'dex_vs_amm_risk_literacy',
  ];
  return moduleIds.map(id => ({ params: { id } }));
}

const { id } = Astro.params;
---

<DashboardLayout title="Run Module" activePage="modules">

  <div id="run-page" class="space-y-6" data-module-id={id}>

    <!-- Header (loaded dynamically) -->
    <div>
      <a href={`/xrpl-lab/app/modules/${id}/`} class="text-sm text-slate-400 hover:text-emerald-400 transition-colors mb-2 inline-block">&larr; Back to Module</a>
      <div class="flex items-center gap-3 mt-1">
        <h1 id="run-title" class="text-2xl font-bold text-slate-100">Loading...</h1>
        <span id="run-badge" class="inline-block px-2 py-0.5 text-xs font-medium rounded border border-slate-600 text-slate-400"></span>
      </div>
    </div>

    <!-- Controls -->
    <!-- F-FE-C-008: aria-label clarifies that Run hits the live testnet and
         Dry Run simulates offline; the visible glyphs (▶/📋) are decorative
         and marked aria-hidden so screen readers announce the explanatory
         label, not the unicode codepoints. -->
    <div class="flex items-center gap-3">
      <button
        id="btn-run"
        aria-label="Run module live (real testnet transactions)"
        class="px-5 py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-semibold rounded transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
      >
        <span aria-hidden="true">&#9654;</span> Run
      </button>
      <button
        id="btn-dry"
        aria-label="Run module in dry-run mode (offline simulated transactions)"
        class="px-5 py-2.5 bg-slate-700 hover:bg-slate-600 text-slate-200 text-sm font-semibold rounded border border-slate-600 transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
      >
        <span aria-hidden="true">&#128203;</span> Dry Run
      </button>
      <span id="run-status-label" class="text-sm text-slate-400 ml-2" role="status" aria-live="polite"></span>
    </div>

    <!-- Main content area: terminal + sidebar -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-4">

      <!-- Terminal output -->
      <section class="order-2 lg:order-1">
        <div class="bg-slate-950 rounded-lg border border-slate-700 overflow-hidden">
          <div class="flex items-center gap-2 px-4 py-2 bg-slate-900 border-b border-slate-700">
            <!-- F-FE-C-008: decorative traffic-light dots — purely visual chrome,
                 hidden from assistive tech to avoid noise. -->
            <span class="w-3 h-3 rounded-full bg-red-500/60" aria-hidden="true"></span>
            <span class="w-3 h-3 rounded-full bg-amber-500/60" aria-hidden="true"></span>
            <span class="w-3 h-3 rounded-full bg-emerald-500/60" aria-hidden="true"></span>
            <span class="text-xs text-slate-500 ml-2 font-mono">output</span>
          </div>
          <div
            id="terminal"
            class="p-4 font-mono text-sm text-emerald-400 h-96 overflow-y-auto whitespace-pre-wrap"
          >
            <span class="text-slate-600">Waiting to start...</span>
          </div>
        </div>
      </section>

      <!-- Step sidebar -->
      <aside class="order-1 lg:order-2">
        <div class="bg-slate-800 rounded-lg border border-slate-700 p-4">
          <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Steps</h2>
          <!-- F-FE-C-011: aria-live="polite" announces step transitions to
               screen-reader users without interrupting; aria-atomic="false"
               so only the changed nodes are read, not the whole list each
               time. Reserved "assertive" for genuine alerts. -->
          <div id="step-list" class="space-y-2" aria-live="polite" aria-atomic="false" aria-label="Run steps">
            <p class="text-sm text-slate-600">Steps appear when run starts.</p>
          </div>
        </div>
      </aside>

    </div>

    <!-- Transactions -->
    <section id="tx-section" class="hidden">
      <div class="bg-slate-800 rounded-lg border border-slate-700 p-4">
        <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Transactions</h2>
        <ul id="tx-list" class="space-y-1.5 font-mono text-xs"></ul>
      </div>
    </section>

    <!-- Completion banner -->
    <div id="completion-banner" class="hidden rounded-lg border p-5"></div>

  </div>

  <script>
    import { fetchWithTimeout } from '../../../lib/api';

    const API_BASE = 'http://localhost:8321';

    function escapeHtml(str: any): string {
      if (!str) return '';
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    const container = document.getElementById('run-page');
    const moduleId = container?.dataset.moduleId || '';

    const levelColors: Record<string, string> = {
      beginner: 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30',
      intermediate: 'bg-amber-500/20 text-amber-400 border-amber-500/30',
      advanced: 'bg-red-500/20 text-red-400 border-red-500/30',
    };

    // Check URL params for auto-start
    const urlParams = new URLSearchParams(window.location.search);
    const autoDryRun = urlParams.get('dry_run');

    // State
    let ws: WebSocket | null = null;
    let running = false;
    let steps: Array<{ action: string; status: 'pending' | 'running' | 'done' | 'failed' }> = [];
    let txids: string[] = [];
    // B-FRONTEND-005: index of the step currently marked 'running'. The server's
    // 'step_complete' frame carries only {action, success} — NO index — but it is
    // always emitted for the SAME step that just emitted its 'step' frame (see
    // runner.py: on_step then on_step_complete within one loop iteration). So we
    // complete the row at currentStepIndex rather than matching by action STRING,
    // which is fragile when two steps share an action (e.g. two verify_tx steps).
    let currentStepIndex = -1;
    // B-FRONTEND-005: short labels derived from the module's step list (loaded via
    // GET /api/modules/{id}), used to label rows as soon as steps initialize —
    // before the matching 'step' frame arrives — instead of a bare "Step N".
    let moduleStepLabels: string[] = [];

    // WS reconnect state (F-FE-B-004)
    const MAX_RECONNECT = 5;
    const MAX_LIFETIME_RECONNECTS = 20;  // F-FE-B-006: lifetime cap (~5min given exponential backoff)
    const BASE_DELAY_MS = 500;
    let reconnectAttempts = 0;            // resets on first message of each cycle (transient blips)
    let lifetimeReconnects = 0;           // F-FE-B-006: never resets; total since page load
    let userInitiatedClose = false;
    let activeRunId: string | null = null;

    // B-BRIDGE-NET-003: liveness watchdog. The server sends a {type:'ping'}
    // keepalive every ~30s when the run queue is idle (runner_ws.py). If NO
    // frame — including that ping — arrives within WATCHDOG_TIMEOUT_MS, the
    // server has silently hung (no data, no close event): the run page would
    // otherwise freeze with no feedback and no reconnect. We track the last
    // message time and surface a clear "stalled" state with a reload affordance.
    // Timeout is 45s: comfortably past the 30s ping interval (one missed ping
    // is tolerated as a transient blip) but short enough to flag a real hang.
    const WATCHDOG_TIMEOUT_MS = 45000;
    let watchdogTimer: number | null = null;
    let lastMessageAt = 0;

    // Suppress reconnect on page navigation. Named handler so the
    // astro:before-swap cleanup (B-FRONTEND-004) can remove it on client-side
    // nav, mirroring the facilitator page's beforeunloadHandler.
    const beforeunloadHandler = () => {
      userInitiatedClose = true;
    };
    window.addEventListener('beforeunload', beforeunloadHandler);

    // Elements
    const terminal = document.getElementById('terminal')!;
    const stepList = document.getElementById('step-list')!;
    const txSection = document.getElementById('tx-section')!;
    const txList = document.getElementById('tx-list')!;
    const completionBanner = document.getElementById('completion-banner')!;
    const btnRun = document.getElementById('btn-run') as HTMLButtonElement;
    const btnDry = document.getElementById('btn-dry') as HTMLButtonElement;
    const statusLabel = document.getElementById('run-status-label')!;

    // Load module info
    async function loadModuleInfo() {
      try {
        const modRes = await fetchWithTimeout(`${API_BASE}/api/modules/${moduleId}`);
        const mod = await modRes.json();
        const title = document.getElementById('run-title');
        if (title) title.textContent = mod.title || moduleId;
        const badge = document.getElementById('run-badge');
        if (badge && mod.level) {
          badge.textContent = mod.level;
          badge.className = `inline-block px-2 py-0.5 text-xs font-medium rounded border ${levelColors[mod.level] || ''}`;
        }
        // B-FRONTEND-005: cache short per-step labels from the module's known
        // step list so the sidebar can show meaningful row labels immediately,
        // not "Step N" until each server frame arrives. The API returns full
        // step TEXT (markdown); we take the first line, strip leading markdown
        // heading markers, and cap length for a compact sidebar label. Indices
        // align with the WS 'step' frame index (both enumerate module.steps).
        if (Array.isArray(mod.steps)) {
          moduleStepLabels = mod.steps.map((text: any) => {
            const firstLine = String(text || '').split('\n')[0].replace(/^#+\s*/, '').trim();
            return firstLine.length > 48 ? firstLine.slice(0, 47) + '…' : firstLine;
          });
        }
      } catch {
        const title = document.getElementById('run-title');
        if (title) title.textContent = moduleId;
      }
    }

    // Terminal helpers
    function termClear() {
      terminal.innerHTML = '';
    }

    function termAppend(text: string, cls: string = 'text-emerald-400') {
      const span = document.createElement('span');
      span.className = cls;
      span.textContent = text + '\n';
      terminal.appendChild(span);
      terminal.scrollTop = terminal.scrollHeight;
    }

    // Step sidebar render
    function renderSteps() {
      if (steps.length === 0) {
        stepList.innerHTML = '<p class="text-sm text-slate-600">Steps appear when run starts.</p>';
        return;
      }
      // F-FE-C-011 + F-FE-C-008: status-glyph wrapper is decorative; the
      // status word is included in the row's aria-label so screen readers
      // hear "Step 2: Submit payment, running" when aria-live announces the
      // change. Color is a redundant cue, not the only one.
      stepList.innerHTML = steps.map((s, i) => {
        let icon = '<span class="text-slate-600">&#9675;</span>';      // pending
        let textCls = 'text-slate-500';
        let statusWord = 'pending';
        if (s.status === 'running') {
          icon = '<span class="text-emerald-400 animate-pulse">&#9679;</span>';
          textCls = 'text-emerald-400 font-semibold';
          statusWord = 'running';
        } else if (s.status === 'done') {
          icon = '<span class="text-emerald-500">&#10003;</span>';
          textCls = 'text-slate-300';
          statusWord = 'done';
        } else if (s.status === 'failed') {
          icon = '<span class="text-red-500">&#10007;</span>';
          textCls = 'text-red-400';
          statusWord = 'failed';
        }
        const action = escapeHtml(s.action);
        return `<div class="flex items-start gap-2 text-sm" aria-label="Step ${i + 1}: ${action}, ${statusWord}">
          <span class="shrink-0 w-5 text-center mt-0.5" aria-hidden="true">${icon}</span>
          <span class="${textCls}">${i + 1}. ${action}</span>
        </div>`;
      }).join('');
    }

    // ── Liveness watchdog (B-BRIDGE-NET-003) ───────────────────────────
    // A silently-hung server sends no frames AND never closes the socket, so
    // neither the 'message' nor the 'close' handler ever fires — the page just
    // freezes. The watchdog is the only path that detects this: it polls the
    // gap since the last received frame and trips if it exceeds the timeout.
    // The server's 30s keepalive ping is what keeps lastMessageAt fresh on a
    // healthy-but-idle run, so a tripped watchdog genuinely means "no ping, no
    // data — the server stopped responding."

    function stopWatchdog() {
      if (watchdogTimer !== null) {
        window.clearInterval(watchdogTimer);
        watchdogTimer = null;
      }
    }

    function startWatchdog() {
      stopWatchdog();
      lastMessageAt = Date.now();
      // Poll at a fraction of the timeout so we trip within a few seconds of
      // the deadline rather than only on exact multiples of the timeout.
      watchdogTimer = window.setInterval(() => {
        if (!running) {
          stopWatchdog();
          return;
        }
        if (Date.now() - lastMessageAt > WATCHDOG_TIMEOUT_MS) {
          handleStalledConnection();
        }
      }, 5000);
    }

    // Called when the watchdog detects no frames (not even the keepalive ping)
    // within WATCHDOG_TIMEOUT_MS. Surfaces a clear, actionable stalled state
    // and stops streaming — the server is unresponsive, so reconnecting to the
    // same run is unlikely to help (and the run may already be lost). We give
    // the user a Reload affordance rather than silently spinning forever.
    function handleStalledConnection() {
      stopWatchdog();
      running = false;
      // Tear down the dead socket so its eventual late 'close' doesn't trigger
      // a reconnect cycle on top of the stalled state. userInitiatedClose
      // suppresses the reconnect path in the close handler.
      userInitiatedClose = true;
      try { ws?.close(); } catch { /* already closing */ }

      btnRun.disabled = false;
      btnDry.disabled = false;
      statusLabel.textContent = 'Connection stalled';
      statusLabel.className = 'text-sm text-red-400 ml-2';
      termAppend(
        '\n[stalled] No response from the server for ' +
          Math.round(WATCHDOG_TIMEOUT_MS / 1000) +
          's (the keepalive ping stopped arriving). Reload to reconnect.',
        'text-red-400'
      );

      // Surface a banner with a reload affordance so the user isn't left
      // staring at a frozen page. role="alert" so screen readers announce it.
      completionBanner.className = 'rounded-lg border p-5 bg-red-500/10 border-red-500/30';
      completionBanner.setAttribute('role', 'alert');
      completionBanner.innerHTML = `
        <div class="flex items-center gap-3">
          <span class="text-3xl text-red-400" aria-hidden="true">&#9888;</span>
          <div>
            <p class="text-lg font-semibold text-red-400">Connection stalled — the server isn't responding.</p>
            <p class="text-sm text-slate-400 mt-1">No data or keepalive ping arrived for ${Math.round(WATCHDOG_TIMEOUT_MS / 1000)}s. Reload to reconnect.</p>
            <button
              id="stalled-reload"
              type="button"
              class="mt-3 px-4 py-2 bg-red-500 hover:bg-red-400 text-slate-900 font-semibold text-sm rounded transition-colors"
            >Reload page</button>
          </div>
        </div>`;
      completionBanner.classList.remove('hidden');
      document.getElementById('stalled-reload')?.addEventListener('click', () => {
        window.location.reload();
      });
    }

    // Connect (or reconnect) to the run WebSocket. Uses module-scoped
    // activeRunId so reconnect attempts target the same run.
    function connectWS() {
      const wsBase = API_BASE.replace(/^http/, 'ws');
      ws = new WebSocket(`${wsBase}/api/run/${moduleId}/ws?run_id=${activeRunId}`);

      let firstMessageSeen = false;

      // B-BRIDGE-NET-003: (re)start the liveness watchdog for this socket. Each
      // (re)connect resets the clock so a fresh, healthy socket isn't tripped by
      // a gap that predates it.
      startWatchdog();

      ws.addEventListener('message', (event) => {
        // B-BRIDGE-NET-003: any frame — data OR the server's keepalive ping —
        // proves the connection is alive; refresh the watchdog clock.
        lastMessageAt = Date.now();
        // Reset reconnect budget once the new socket has actually delivered data,
        // so a transient blip every ~30s doesn't burn the attempt budget over time.
        if (!firstMessageSeen) {
          firstMessageSeen = true;
          reconnectAttempts = 0;
        }
        try {
          const msg = JSON.parse(event.data);
          handleMessage(msg);
        } catch {
          // ignore
        }
      });

      ws.addEventListener('close', (event) => {
        // B-BRIDGE-NET-003: this socket is gone — stop its watchdog. If we go on
        // to reconnect below, connectWS() starts a fresh watchdog for the new
        // socket; if we stop here (terminal close), it stays stopped.
        stopWatchdog();
        // Run already finished (complete handler ran) or page is unloading — don't reconnect.
        if (!running || userInitiatedClose) return;

        // Normal closure (1000) / going-away (1001): server signaled clean end.
        if (event.code === 1000 || event.code === 1001) {
          statusLabel.textContent = 'Connection closed';
          statusLabel.className = 'text-sm text-amber-400 ml-2';
          termAppend('\n[run complete]', 'text-emerald-400');
          running = false;
          btnRun.disabled = false;
          btnDry.disabled = false;
          return;
        }

        // Origin rejection (4003): config error, retrying won't help.
        if (event.code === 4003) {
          statusLabel.textContent = 'Origin rejected';
          statusLabel.className = 'text-sm text-red-400 ml-2';
          termAppend('\n[disconnected] Origin rejected — server config issue. Refresh after fixing.', 'text-red-400');
          running = false;
          btnRun.disabled = false;
          btnDry.disabled = false;
          return;
        }

        // Run not found (4004): F-FE-B-006. Bridge sent this because the session
        // was cleaned up server-side (likely after a transient disconnect that
        // exceeded _CLEANUP_GRACE_SECONDS). Reconnect won't help — the run is gone.
        // F-FE-C-004: teach WHY (idle timeout protects server memory) so the
        // user understands the cleanup, not just that it happened, and gets a
        // tip to avoid it next time.
        if (event.code === 4004) {
          statusLabel.textContent = 'Run cleaned up';
          statusLabel.className = 'text-sm text-amber-400 ml-2';
          termAppend(
            '\n[disconnected] This run was cleaned up — the session expired after the WebSocket disconnected (idle timeout protects server memory). Start a new run from the Modules page; tip: keep the dashboard tab active during runs.',
            'text-amber-400'
          );
          running = false;
          btnRun.disabled = false;
          btnDry.disabled = false;
          return;
        }

        // F-FE-B-006: lifetime cap on total reconnects since page load.
        // Per-cycle cap (MAX_RECONNECT) intentionally resets on first message
        // to absorb transient blips; this is the SEPARATE layer that prevents
        // pathological infinite reconnect (e.g. server drops every connection
        // on its 1st message).
        if (lifetimeReconnects >= MAX_LIFETIME_RECONNECTS) {
          statusLabel.textContent = 'Disconnected';
          statusLabel.className = 'text-sm text-red-400 ml-2';
          termAppend(
            `\n[disconnected] Connection lost (${lifetimeReconnects} reconnects exhausted). Refresh page to retry.`,
            'text-red-400'
          );
          running = false;
          btnRun.disabled = false;
          btnDry.disabled = false;
          return;
        }

        if (reconnectAttempts >= MAX_RECONNECT) {
          statusLabel.textContent = 'Disconnected';
          statusLabel.className = 'text-sm text-red-400 ml-2';
          termAppend(`\n[disconnected] Max reconnect attempts (${MAX_RECONNECT}) reached. Refresh to retry.`, 'text-red-400');
          running = false;
          btnRun.disabled = false;
          btnDry.disabled = false;
          return;
        }

        const delay = BASE_DELAY_MS * Math.pow(2, reconnectAttempts);
        const attemptNum = reconnectAttempts + 1;
        statusLabel.textContent = `Reconnecting (${attemptNum}/${MAX_RECONNECT})...`;
        statusLabel.className = 'text-sm text-amber-400 ml-2 animate-pulse';
        termAppend(
          `\n[reconnecting] WS dropped (code=${event.code}). Retry in ${delay / 1000}s (attempt ${attemptNum}/${MAX_RECONNECT})`,
          'text-amber-400'
        );
        reconnectAttempts++;
        lifetimeReconnects++;  // F-FE-B-006: increment lifetime counter
        setTimeout(() => {
          // Re-check before reconnecting in case state changed during the delay.
          if (running && !userInitiatedClose) {
            connectWS();
          }
        }, delay);
      });

      ws.addEventListener('error', () => {
        termAppend('[error] WebSocket connection failed.', 'text-red-400');
      });
    }

    // Start a run
    async function startRun(dryRun: boolean) {
      if (running) return;
      running = true;
      steps = [];
      txids = [];
      currentStepIndex = -1;  // B-FRONTEND-005: reset running-step tracker per run
      reconnectAttempts = 0;
      userInitiatedClose = false;
      activeRunId = null;
      stopWatchdog();  // B-BRIDGE-NET-003: clear any stale watchdog from a prior run

      btnRun.disabled = true;
      btnDry.disabled = true;
      termClear();
      txSection.classList.add('hidden');
      txList.innerHTML = '';
      completionBanner.classList.add('hidden');
      renderSteps();

      const modeLabel = dryRun ? 'DRY RUN' : 'LIVE RUN';
      statusLabel.textContent = `Starting ${modeLabel}...`;
      statusLabel.className = 'text-sm text-emerald-400 ml-2 animate-pulse';
      termAppend(`[${modeLabel}] Starting module: ${moduleId}`, 'text-slate-400');

      try {
        const res = await fetchWithTimeout(`${API_BASE}/api/run/${moduleId}?dry_run=${dryRun}`, { method: 'POST' });
        if (!res.ok) {
          throw new Error(`API returned ${res.status}`);
        }
        const result = await res.json();
        activeRunId = result.run_id;

        termAppend(`[${modeLabel}] Run ID: ${activeRunId}`, 'text-slate-500');
        statusLabel.textContent = `Running...`;

        // Connect WebSocket (auto-reconnect on transient drop, F-FE-B-004)
        connectWS();

      } catch (err: any) {
        let msg: string;
        if (err?.name === 'AbortError') {
          msg = 'Request timed out — check API server is responsive.';
        } else if (err instanceof TypeError) {
          msg = 'Could not reach API server — is it running?';
        } else {
          msg = err.message || 'Failed to start run';
        }
        termAppend(`[error] ${msg}`, 'text-red-400');
        statusLabel.textContent = 'Failed to start';
        statusLabel.className = 'text-sm text-red-400 ml-2';
        running = false;
        btnRun.disabled = false;
        btnDry.disabled = false;
      }
    }

    // Handle incoming WS messages
    function handleMessage(msg: any) {
      switch (msg.type) {
        case 'step': {
          // Initialize steps if first step message. B-FRONTEND-005: seed each
          // row's label from the module's known step list (moduleStepLabels)
          // when available, so rows read e.g. "Submit payment" immediately
          // instead of "Step N" until the matching frame arrives. Fall back to
          // "Step N" only when the label list is missing or shorter than total.
          if (steps.length === 0 && msg.total) {
            for (let i = 0; i < msg.total; i++) {
              steps.push({ action: moduleStepLabels[i] || `Step ${i + 1}`, status: 'pending' });
            }
          }
          // Update current step. B-FRONTEND-005: the server 'step' index is
          // authoritative (it enumerates module.steps); record it as the
          // current running index so the paired 'step_complete' frame — which
          // carries no index — completes THIS row, not whichever row happens
          // to share the action string.
          if (msg.index !== undefined && msg.index < steps.length) {
            // Mark previous as done if it was running
            for (let i = 0; i < steps.length; i++) {
              if (steps[i].status === 'running') steps[i].status = 'done';
            }
            // Prefer the server's live action label; fall back to whatever the
            // row already had (module-derived label or "Step N").
            steps[msg.index].action = msg.action || steps[msg.index].action;
            steps[msg.index].status = 'running';
            currentStepIndex = msg.index;
          }
          renderSteps();
          termAppend(`> Step ${(msg.index || 0) + 1}/${msg.total || '?'}: ${msg.action || '...'}`, 'text-slate-300');
          break;
        }

        case 'output': {
          termAppend(msg.text || '', 'text-emerald-400');
          break;
        }

        case 'step_complete': {
          // B-FRONTEND-005: complete the row at currentStepIndex (set by the
          // paired 'step' frame) instead of findIndex(action === msg.action).
          // The server emits step_complete for the same step that just emitted
          // its 'step' frame, so the running index is the right target — and it
          // is unambiguous even when two steps share an action string. Fall back
          // to action-string matching only if no step is currently tracked
          // (defensive: e.g. a stray frame before any 'step').
          let idx = currentStepIndex;
          if (idx < 0 || idx >= steps.length || steps[idx].status !== 'running') {
            idx = steps.findIndex(s => s.status === 'running');
          }
          if (idx < 0) {
            idx = steps.findIndex(s => s.action === msg.action);
          }
          if (idx >= 0) {
            steps[idx].status = msg.success ? 'done' : 'failed';
          }
          renderSteps();
          const sym = msg.success ? '✓' : '✗';
          const cls = msg.success ? 'text-emerald-500' : 'text-red-500';
          termAppend(`  ${sym} ${msg.action}: ${msg.success ? 'completed' : 'failed'}`, cls);
          break;
        }

        case 'tx': {
          txids.push(msg.txid);
          txSection.classList.remove('hidden');
          const li = document.createElement('li');
          li.className = 'flex items-center gap-2';
          const resultCls = msg.result_code === 'tesSUCCESS' ? 'text-emerald-400' : 'text-amber-400';
          li.innerHTML = `<span class="text-slate-400">#${txids.length}</span>
            <span class="text-slate-300 truncate">${escapeHtml(msg.txid)}</span>
            <span class="${resultCls}">${escapeHtml(msg.result_code)}</span>`;
          txList.appendChild(li);
          termAppend(`  TX: ${msg.txid} [${msg.result_code}]`, 'text-cyan-400');
          break;
        }

        case 'error': {
          termAppend(`[ERROR] ${msg.message || 'Unknown error'}`, 'text-red-400');
          break;
        }

        case 'complete': {
          running = false;
          btnRun.disabled = false;
          btnDry.disabled = false;
          stopWatchdog();  // B-BRIDGE-NET-003: run finished cleanly, no liveness check needed
          ws?.close();

          const success = msg.success;
          statusLabel.textContent = success ? 'Completed' : 'Failed';
          statusLabel.className = success
            ? 'text-sm text-emerald-400 ml-2'
            : 'text-sm text-red-400 ml-2';

          // Mark remaining running steps
          steps.forEach(s => {
            if (s.status === 'running') s.status = success ? 'done' : 'failed';
          });
          renderSteps();

          // Completion banner
          // F-FE-C-008: decorative ✓/✗ glyphs marked aria-hidden — the
          // headline text ("Module completed successfully" / "Module run
          // failed") already names the outcome for screen readers.
          if (success) {
            completionBanner.className = 'rounded-lg border p-5 bg-emerald-500/10 border-emerald-500/30';
            completionBanner.setAttribute('role', 'status');
            completionBanner.innerHTML = `
              <div class="flex items-center gap-3">
                <span class="text-3xl text-emerald-400" aria-hidden="true">&#10003;</span>
                <div>
                  <p class="text-lg font-semibold text-emerald-400">Module completed successfully</p>
                  <p class="text-sm text-slate-400 mt-1">
                    ${msg.txids?.length || 0} transaction(s) submitted.
                    ${msg.report_path ? `<a href="/xrpl-lab/app/artifacts/" class="text-emerald-400 hover:underline ml-1">View artifacts &rarr;</a>` : ''}
                  </p>
                </div>
              </div>`;
          } else {
            completionBanner.className = 'rounded-lg border p-5 bg-red-500/10 border-red-500/30';
            completionBanner.setAttribute('role', 'alert');
            completionBanner.innerHTML = `
              <div class="flex items-center gap-3">
                <span class="text-3xl text-red-400" aria-hidden="true">&#10007;</span>
                <div>
                  <p class="text-lg font-semibold text-red-400">Module run failed</p>
                  <p class="text-sm text-slate-400 mt-1">Check the output above for errors. You can retry the run.</p>
                </div>
              </div>`;
          }
          completionBanner.classList.remove('hidden');

          termAppend(`\n--- Run ${success ? 'PASSED' : 'FAILED'} ---`, success ? 'text-emerald-500' : 'text-red-500');
          break;
        }
      }
    }

    // Wire buttons
    btnRun.addEventListener('click', () => startRun(false));
    btnDry.addEventListener('click', () => startRun(true));

    // Astro client-side navigation cleanup (B-FRONTEND-004). The facilitator
    // page already does this; the run page did NOT, leaving a latent socket +
    // timer leak if Astro's ClientRouter is ever enabled (a return visit would
    // accumulate a live WebSocket and watchdog interval per navigation). Fires
    // before the page unmounts: suppress reconnect, close the WS, stop the
    // watchdog, and remove the beforeunload listener — symmetric with
    // facilitator/runs.astro's cleanup.
    document.addEventListener('astro:before-swap', () => {
      userInitiatedClose = true;   // suppress the close handler's reconnect path
      running = false;
      stopWatchdog();
      try { ws?.close(); } catch { /* already closing */ }
      window.removeEventListener('beforeunload', beforeunloadHandler);
    }, { once: true });

    // Init
    loadModuleInfo();

    // Auto-start if navigated with ?dry_run param
    if (autoDryRun !== null) {
      setTimeout(() => startRun(autoDryRun === 'true'), 300);
    }
  </script>

</DashboardLayout>
