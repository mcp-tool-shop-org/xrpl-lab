---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { getModuleIds } from '../../../lib/module-ids';

export function getStaticPaths() {
  // FRONTEND-A-001: derive the page set from the repo-root modules/ directory
  // (single source of truth) so new curriculum modules are built automatically
  // and never 404 on GitHub Pages. See site/src/lib/module-ids.ts.
  return getModuleIds().map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
---

<DashboardLayout title="Module" activePage="modules">
  <div class="screen-inner" id="module-root" data-module-id={id}>
    <div class="card section"><div class="skeleton" style="height:34px;width:45%"></div></div>
  </div>

  <script>
    import { fetchWithTimeout } from '../../../lib/api';
    import { icons, healthIcon, esc } from '../../../lib/dashboard-ui';

    const API_BASE = 'http://localhost:8321';
    const II = (svg: string) =>
      `<span style="display:inline-flex;width:16px;height:16px;color:var(--text-3)">${svg}</span>`;
    const sk = (h: string, w = '100%') => `<div class="skeleton" style="height:${h};width:${w}"></div>`;

    const backLink =
      `<a class="muted" href="/xrpl-lab/app/modules/" style="font-size:13.5px;text-decoration:none">&larr; Back to Modules</a>`;

    function skeletonDetail() {
      return `<div class="card section">${sk('14px', '18%')}<div style="height:10px"></div>${sk('30px', '45%')}</div>
        <div class="grid section grid-stats">${Array(3).fill(`<div class="stat">${sk('13px', '55%')}${sk('22px', '70%')}</div>`).join('')}</div>
        <div class="card section">${sk('14px', '20%')}<div class="sk-line skeleton"></div><div class="sk-line skeleton" style="width:80%"></div></div>`;
    }

    // 404 / API-unreachable — humanized copy matching the overview page.
    function errorHTML(err: any) {
      let msg = 'Could not load module details. The module may not exist, or the API is offline. Run <code class="mono">xrpl-lab serve</code> in a terminal, then refresh.';
      if (err?.name === 'AbortError') {
        msg = 'Request timed out. The API may be slow or restarting. Refresh to retry.';
      } else if (err?.httpStatus) {
        // FRONTEND-A-005 / FEBCD-001: an HTTP error (e.g. 500) means the server
        // is up but errored — report that honestly instead of "API offline".
        // 404 keeps the "module may not exist" framing it already implies.
        msg = err.httpStatus === 404
          ? 'This module was not found (HTTP 404). It may have been renamed or removed.'
          : `API error (HTTP ${err.httpStatus}). The server is up but returned an error.`;
      }
      return `<div class="screen-head">${backLink}</div>
        <div class="card"><div class="empty"><span class="empty__ic">${icons.alert}</span>
          <div class="empty__t">Can't load this module</div><div>${msg}</div></div></div>`;
    }

    function detailHTML(mod: any, prereqsHTML: string) {
      const prereqList = mod.prerequisites || [];
      const artifacts = mod.artifacts || [];

      // Level chip (neutral pill) + optional completion marker.
      const levelChip = mod.level
        ? `<span class="chip">${esc(mod.level)}</span>`
        : '';
      const completedMark = mod.completed
        ? `<span class="row" style="gap:6px;color:var(--accent-bright);font-size:13.5px;font-weight:600">${healthIcon('pass')} Completed</span>`
        : '';

      const desc = mod.description
        ? `<p class="lede">${esc(mod.description)}</p>`
        : '';

      // Steps preview — ordered list, falls back to an empty note.
      const steps = mod.steps || [];
      const stepsBlock = steps.length
        ? `<ol class="mod-steps" style="margin:0;padding-left:20px;display:flex;flex-direction:column;gap:8px;font-size:var(--fs-sm);color:var(--text)">${steps.map((s: string) => `<li>${esc(s)}</li>`).join('')}</ol>`
        : `<p class="muted">No steps listed for this module.</p>`;

      return `
      <div class="screen-head">
        ${backLink}
        <div class="row" style="gap:12px;margin-top:8px;flex-wrap:wrap">
          <h1 style="margin:0">${esc(mod.title || mod.id)}</h1>
          ${levelChip}
          ${completedMark}
        </div>
        ${desc}
      </div>

      <div class="grid section grid-stats">
        <div class="stat"><span class="stat__label">${II(icons.book)} Time estimate</span><span class="stat__value" style="font-size:18px">${esc(mod.time_estimate || '--')}</span></div>
        <div class="stat"><span class="stat__label">${II(icons.clip)} Prerequisites</span><span class="stat__value" style="font-size:18px">${prereqList.length || 'None'}</span></div>
        <div class="stat"><span class="stat__label">${II(icons.seal)} Artifacts</span><span class="stat__value" style="font-size:18px">${artifacts.length || '--'}</span></div>
      </div>

      <div class="card section">
        <p class="eyebrow">Steps preview</p>
        ${stepsBlock}
      </div>

      ${prereqsHTML}

      <div class="row section" style="gap:12px;flex-wrap:wrap">
        <a class="btn btn--primary" href="/xrpl-lab/app/run/${esc(mod.id)}/?dry_run=false">${icons.play} Run Module</a>
        <a class="btn" href="/xrpl-lab/app/run/${esc(mod.id)}/?dry_run=true">Run in Dry Mode</a>
        ${mod.completed ? `<span class="row" style="gap:6px;margin-left:auto;color:var(--accent-bright);font-size:13.5px;font-weight:600">${healthIcon('pass')} Module completed</span>` : ''}
      </div>`;
    }

    // Build the prerequisites card by cross-fetching /api/modules to resolve
    // each prereq's title + completion. Returns '' when there are none, or a
    // best-effort card (skipping the detail section) if the cross-fetch fails.
    async function prereqsCard(mod: any): Promise<string> {
      const prereqList = mod.prerequisites || [];
      if (!prereqList.length) return '';
      let moduleMap: Map<string, any>;
      try {
        const allModules = await (await fetchWithTimeout(`${API_BASE}/api/modules`)).json();
        moduleMap = new Map(allModules.map((m: any) => [m.id, m]));
      } catch {
        // skip prerequisites detail on error
        return '';
      }
      const rows = prereqList.map((pid: string) => {
        const pm = moduleMap.get(pid) as any;
        const completed = pm?.completed;
        const title = pm?.title || pid;
        const status = completed
          ? `<span style="margin-left:auto;font-size:12px;color:var(--accent-bright);font-weight:600">Completed</span>`
          : `<span style="margin-left:auto;font-size:12px;color:var(--warn-bright);font-weight:600">Not completed</span>`;
        return `<div class="check" style="align-items:center">${healthIcon(completed ? 'pass' : 'warn')}
          <div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0">
            <a class="check__name" href="/xrpl-lab/app/modules/${esc(pid)}/" style="text-decoration:none">${esc(title)}</a>
            ${status}
          </div></div>`;
      }).join('');
      return `<div class="card section"><p class="eyebrow">Prerequisites</p><div class="checks">${rows}</div></div>`;
    }

    async function hydrate() {
      const root = document.getElementById('module-root');
      if (!root) return;
      const moduleId = root.dataset.moduleId;
      if (!moduleId) return;
      root.innerHTML = skeletonDetail();

      let mod: any;
      try {
        const res = await fetchWithTimeout(`${API_BASE}/api/modules/${moduleId}`);
        if (!res.ok) {
          // FEBCD-001: tag with the HTTP status so errorHTML reports it honestly
          // (e.g. "API error (HTTP 500)") rather than parsing an error body as
          // JSON and mislabeling a server fault as "offline" — mirrors the
          // sibling pages (modules/index, artifacts, doctor) hardened earlier.
          const e = new Error(`API returned ${res.status}: ${res.statusText}`);
          (e as any).httpStatus = res.status;
          throw e;
        }
        mod = await res.json();
      } catch (err) {
        root.innerHTML = errorHTML(err);
        return;
      }

      const prereqsHTML = await prereqsCard(mod);
      root.innerHTML = detailHTML(mod, prereqsHTML);
    }

    hydrate();
  </script>
</DashboardLayout>
