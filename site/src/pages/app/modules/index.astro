---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Modules" activePage="modules">
  <div class="screen-head">
    <h1>Modules</h1>
    <p class="lede">12 hands-on modules. Pick a track and work through them at your own pace.</p>
  </div>

  <div class="screen-inner" id="modules-root">
    <!-- Filter bar — a segmented control (.seg). aria-pressed signals the
         active level to screen-reader users AND drives the active styling
         (`.seg button[aria-pressed="true"]`), so the two never drift.
         Kept in sync in applyFilter(). -->
    <div class="seg seg--wrap section" role="group" aria-label="Filter modules by level">
      <button data-filter="all" aria-pressed="true">All</button>
      <button data-filter="beginner" aria-pressed="false">Beginner</button>
      <button data-filter="intermediate" aria-pressed="false">Intermediate</button>
      <button data-filter="advanced" aria-pressed="false">Advanced</button>
    </div>

    <!-- Module grid — skeleton tiles mirror the real-card structure (title
         row + chip/time row) so the loading→loaded swap has no layout shift. -->
    <div id="module-grid" class="grid"></div>
  </div>

  <script>
    import { fetchWithTimeout } from '../../../lib/api';
    import { icons, healthIcon, esc } from '../../../lib/dashboard-ui';

    const API_BASE = 'http://localhost:8321';
    const sk = (h: string, w = '100%') => `<div class="skeleton" style="height:${h};width:${w}"></div>`;

    // API shape is dynamic; keep the field names the backend sends.
    interface Module {
      id: string;
      title: string;
      track?: string;
      level: string;
      time_estimate?: string;
      mode?: string;
      completed?: boolean;
      is_next?: boolean;
    }

    let allModules: Module[] = [];

    // Three skeleton tiles, each approximating a real card's title bar +
    // chip/time row, so the grid doesn't reflow when data lands.
    function skeletonGrid() {
      return Array(3).fill(
        `<div class="card">${sk('17px', '70%')}<div class="row" style="gap:10px;margin-top:14px">${sk('20px', '78px')}${sk('14px', '60px')}</div></div>`
      ).join('');
    }

    // F-FE-D-006: every tile carries a completion marker in the same slot —
    // healthIcon('pass') for completed, a hollow dot for not-started — so the
    // grid never has a blank slot and both states are labelled for SR users.
    function completionMark(done: boolean) {
      return done
        ? healthIcon('pass')
        : `<span class="statdot" role="img" aria-label="Not yet completed" style="width:14px;height:14px;background:none;border:1.5px solid var(--line-strong);border-radius:50%"></span>`;
    }

    function renderModules(modules: Module[]) {
      const grid = document.getElementById('module-grid');
      if (!grid) return;

      if (modules.length === 0) {
        grid.innerHTML = `<div class="card"><div class="empty"><span class="empty__ic">${icons.inbox}</span>
          <div class="empty__t">No modules here</div><div>No modules match this level. Try a different filter.</div></div></div>`;
        return;
      }

      grid.innerHTML = modules.map((m) => {
        // is_next earns a subtle accent border + an "Up next" label so the
        // recommended module reads at a glance without relying on hue alone.
        const next = m.is_next
          ? ' style="border-color:var(--ok-edge)"'
          : '';
        const nextTag = m.is_next
          ? `<span class="chip" style="background:var(--ok-fill);border-color:var(--ok-edge);color:var(--accent-bright)">Up next</span>`
          : '';
        const time = m.time_estimate
          ? `<span class="muted nowrap" style="font-size:13px">${esc(m.time_estimate)}</span>`
          : '';
        return `
        <a class="qa" href="/xrpl-lab/app/modules/${esc(m.id)}/" data-level="${esc(m.level)}"${next}>
          <div class="row row--between" style="gap:12px;align-items:flex-start">
            <span class="qa__t">${esc(m.title)}</span>
            ${completionMark(!!m.completed)}
          </div>
          <div class="row" style="gap:10px;flex-wrap:wrap;margin-top:6px">
            <span class="chip">${esc(m.level)}</span>
            ${nextTag}
            ${time}
          </div>
        </a>`;
      }).join('');
    }

    function applyFilter(level: string) {
      const filtered = level === 'all'
        ? allModules
        : allModules.filter((m) => m.level === level);
      renderModules(filtered);

      document.querySelectorAll('.seg button').forEach((btn) => {
        const f = (btn as HTMLElement).dataset.filter;
        // Keep aria-pressed in sync with the active filter — it both tells
        // SR users "Beginner, pressed" and triggers the .seg active styling.
        btn.setAttribute('aria-pressed', f === level ? 'true' : 'false');
      });
    }

    document.querySelectorAll('.seg button').forEach((btn) => {
      btn.addEventListener('click', () => {
        applyFilter((btn as HTMLElement).dataset.filter || 'all');
      });
    });

    function offlineHTML(err: any) {
      // F-FE-C-003: distinguish AbortError (timeout — retrying may help) from
      // TypeError (network/server down — `xrpl-lab serve` not running) so the
      // user gets an actionable hint per error class.
      const timeout = err?.name === 'AbortError';
      const msg = timeout
        ? 'Request timed out. The API may be slow or restarting. Refresh to retry.'
        : 'API is offline. Run <code class="mono">xrpl-lab serve</code> in a terminal, then refresh.';
      return `<div class="card"><div class="empty"><span class="empty__ic">${icons.alert}</span>
        <div class="empty__t">Can't reach the API</div><div>${msg}</div></div></div>`;
    }

    async function loadModules() {
      const grid = document.getElementById('module-grid');
      if (!grid) return;
      grid.innerHTML = skeletonGrid();
      try {
        const res = await fetchWithTimeout(`${API_BASE}/api/modules`);
        allModules = await res.json();
        renderModules(allModules);
      } catch (err: any) {
        grid.innerHTML = offlineHTML(err);
      }
    }

    loadModules();
  </script>
</DashboardLayout>
