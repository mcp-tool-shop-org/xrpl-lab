---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Artifacts" activePage="artifacts">
  <div class="screen-head">
    <h1>Artifacts</h1>
    <p class="lede">Your verifiable training outputs — proof pack, certificate, and reports.</p>
  </div>

  <div class="screen-inner" id="artifacts-root">
    <div class="tabs" role="tablist" aria-label="Artifacts">
      <button class="tab" role="tab" id="tab-proof" aria-controls="panel-proof" aria-selected="true" tabindex="0"><span class="sr-only">Proof Pack</span></button>
    </div>
    <div class="card section"><div class="skeleton" style="height:46px;width:60%"></div></div>
  </div>

  <script>
    import { fetchWithTimeout } from '../../lib/api';
    import { icons, healthIcon, esc, downloadFile } from '../../lib/dashboard-ui';

    // Canonical API base — update in all app pages if port changes
    const API_BASE = 'http://localhost:8321';

    // FT-PROOF-002: retain the already-fetched raw objects so the Download
    // buttons can serialize them to a Blob with NO extra backend call. Keyed by
    // a stable id used in the button's data-dl attribute. Reports are keyed by
    // index (data-dl="report:N") since there can be many.
    const downloads: Record<string, { data: unknown; filename: string; mime: string }> = {};

    const II = (svg: string) =>
      `<span style="display:inline-flex;width:16px;height:16px;color:var(--text-3)">${svg}</span>`;
    const sk = (h: string, w = '100%') => `<div class="skeleton" style="height:${h};width:${w}"></div>`;

    // Humanized fetch-error copy — mirrors the overview page's tone.
    // FRONTEND-A-005: an HTTP error (e.g. a 500 with an HTML body) is neither a
    // TypeError nor an AbortError, so it must NOT be mislabeled "API offline".
    // We tag those errors with `.httpStatus` (see the !res.ok throws below) and
    // report the status honestly here.
    function describeFetchError(err: any, fallback: string): string {
      if (err?.name === 'AbortError') return 'Request timed out — check API server is responsive.';
      if (err instanceof TypeError) return 'Could not reach API server — is it running?';
      if (err?.httpStatus) return `API error (HTTP ${err.httpStatus}). The server is up but returned an error.`;
      return fallback;
    }

    // Throw a tagged Error for a non-OK response so describeFetchError can
    // report the status instead of the page silently treating it as offline.
    function httpError(res: Response): Error {
      const e = new Error(`API returned ${res.status}: ${res.statusText}`);
      (e as any).httpStatus = res.status;
      return e;
    }

    function offlineHTML(err: any) {
      const timeout = err?.name === 'AbortError';
      const msg = timeout
        ? 'Request timed out. The API may be slow or restarting. Refresh to retry.'
        : 'API is offline. Run <code class="mono">xrpl-lab serve</code> in a terminal, then refresh.';
      return `<div class="empty"><span class="empty__ic">${icons.alert}</span>
        <div class="empty__t">Can't reach the API</div><div>${msg}</div></div>`;
    }

    function emptyHTML(icon: string, title: string, help: string) {
      return `<div class="empty"><span class="empty__ic">${icon}</span>
        <div class="empty__t">${title}</div><div>${help}</div></div>`;
    }

    // A hashbox with an inline copy button + transient "Copied!" feedback.
    function hashboxHTML(hash: string) {
      return `<div class="row" style="gap:10px;align-items:flex-start">
        <div class="hashbox" style="flex:1">${esc(hash)}</div>
        <button class="btn btn--sm copy-hash" type="button" data-hash="${esc(hash)}" style="flex:none">
          ${II(icons.clip)}<span>Copy</span></button>
      </div>`;
    }

    // FT-PROOF-002: a Download button bound to a retained raw object by id.
    // wireDownloads() reads the `downloads[id]` record on click and serializes
    // it to a Blob — no backend round-trip (the data is already in the browser).
    function downloadBtnHTML(id: string) {
      return `<button class="btn btn--sm dl-artifact" type="button" data-dl="${esc(id)}">
        ${II(icons.file)}<span>Download</span></button>`;
    }

    /* ---------- skeletons ---------- */
    function skeletonPanel() {
      return `<p class="eyebrow">${sk('11px', '30%')}</p>
        <div class="section">${sk('14px', '70%')}</div>
        <div class="section">${sk('44px', '100%')}</div>
        ${Array(3).fill(`<div class="proofmod">${sk('20px', '20px')}${sk('13px', '40%')}</div>`).join('')}`;
    }

    /* ---------- proof pack panel ---------- */
    function proofHTML(p: any) {
      if (!p || !p.version) {
        return emptyHTML(icons.seal, 'No proof pack yet',
          'Complete modules to generate a verifiable proof pack.');
      }
      const modules = Array.isArray(p.modules) ? p.modules : [];
      const generated = p.generated ? new Date(p.generated).toLocaleString() : 'unknown';

      // FT-PROOF-002: retain the raw object for the Download button.
      downloads['proof'] = { data: p, filename: 'xrpl_lab_proof_pack.json', mime: 'application/json' };

      const integrity = p.integrity
        ? `<p class="eyebrow" style="margin-top:18px">Integrity · SHA-256</p>${hashboxHTML(p.integrity)}`
        : '';

      const mods = modules.length
        ? `<p class="eyebrow" style="margin-top:18px">Modules</p>${modules.map((m: any) => {
            const txCount = Array.isArray(m.txids) ? m.txids.length : 0;
            return `<div class="proofmod">${healthIcon(m.completed ? 'pass' : 'fail')}
              <span class="proofmod__id">${esc(m.id)}</span>
              <span class="proofmod__tx">${txCount} tx${txCount === 1 ? '' : 's'}</span></div>`;
          }).join('')}`
        : `<p class="muted" style="margin-top:18px">No modules recorded in this proof pack.</p>`;

      return `<div class="row" style="justify-content:space-between;align-items:flex-start;gap:12px">
          <p class="eyebrow" style="margin:0">Proof pack · v${esc(p.version)}</p>
          ${downloadBtnHTML('proof')}
        </div>
        <dl class="kv" style="margin-top:12px"><dt>Generated</dt><dd class="mono">${esc(generated)}</dd></dl>
        ${integrity}
        ${mods}`;
    }

    /* ---------- certificate panel ---------- */
    function certHTML(c: any) {
      if (!c || !c.holder) {
        return emptyHTML(icons.award, 'No certificate yet',
          'Finish the workbook to earn a completion certificate.');
      }
      const issued = c.issued ? new Date(c.issued).toLocaleString() : 'unknown';
      const mods = Array.isArray(c.modules_completed) ? c.modules_completed : [];
      const chips = mods.length
        ? mods.map((m: any) => `<span class="chip">${esc(m)}</span>`).join(' ')
        : '<span class="muted">none</span>';

      // FT-PROOF-002: retain the raw object for the Download button.
      downloads['cert'] = { data: c, filename: 'xrpl_lab_certificate.json', mime: 'application/json' };

      const hashbox = c.hash
        ? `<p class="eyebrow" style="margin-top:18px">Certificate hash</p>${hashboxHTML(c.hash)}`
        : '';

      return `<div class="row" style="justify-content:space-between;align-items:flex-start;gap:12px">
          <p class="eyebrow" style="margin:0">Certificate of completion</p>
          ${downloadBtnHTML('cert')}
        </div>
        <dl class="kv" style="margin-top:12px">
          <dt>${II(icons.award)} Holder</dt><dd>${esc(c.holder)}</dd>
          <dt>Issued</dt><dd class="mono">${esc(issued)}</dd>
          <dt>Modules completed</dt><dd>${chips}</dd>
        </dl>
        ${hashbox}`;
    }

    /* ---------- reports panel ---------- */
    // Build a filesystem-safe <report>.md filename from the report title,
    // falling back to a stable index when the title is empty/odd.
    function reportFilename(title: string, idx: number): string {
      const slug = String(title || '')
        .trim().toLowerCase()
        .replace(/[^a-z0-9]+/g, '_')
        .replace(/^_+|_+$/g, '');
      return `${slug || `report_${idx + 1}`}.md`;
    }

    function reportsHTML(reports: any) {
      if (!Array.isArray(reports) || reports.length === 0) {
        return emptyHTML(icons.file, 'No reports yet',
          'No reports generated yet. Complete a module to generate reports.');
      }
      return reports.map((r: any, idx: number) => {
        const date = r.generated ? new Date(r.generated).toLocaleDateString() : '';
        // FT-PROOF-002: retain each report's markdown for its Download button.
        const id = `report:${idx}`;
        downloads[id] = {
          data: typeof r.content === 'string' ? r.content : '',
          filename: reportFilename(r.title, idx),
          mime: 'text/markdown',
        };
        return `<div class="report">
          <div class="report__head">
            <span class="report__title">${esc(r.title)}</span>
            <span class="row" style="gap:10px;align-items:center">
              <span class="report__date">${esc(date)}</span>
              ${downloadBtnHTML(id)}
            </span>
          </div>
          <pre class="report__body">${esc(r.content)}</pre>
        </div>`;
      }).join('');
    }

    /* ---------- shell: tablist + panels ---------- */
    function shellHTML(proof: string, cert: string, reports: string) {
      return `
      <div class="tabs" role="tablist" aria-label="Artifacts">
        <button class="tab" role="tab" id="tab-proof" aria-controls="panel-proof" aria-selected="true" tabindex="0">${icons.seal}<span>Proof Pack</span></button>
        <button class="tab" role="tab" id="tab-cert" aria-controls="panel-cert" aria-selected="false" tabindex="-1">${icons.award}<span>Certificate</span></button>
        <button class="tab" role="tab" id="tab-reports" aria-controls="panel-reports" aria-selected="false" tabindex="-1">${icons.file}<span>Reports</span></button>
      </div>
      <div class="tabpanel card" role="tabpanel" id="panel-proof" aria-labelledby="tab-proof" tabindex="0">${proof}</div>
      <div class="tabpanel card" role="tabpanel" id="panel-cert" aria-labelledby="tab-cert" tabindex="0" hidden>${cert}</div>
      <div class="tabpanel" role="tabpanel" id="panel-reports" aria-labelledby="tab-reports" tabindex="0" hidden>${reports}</div>`;
    }

    /* ---------- accessible tablist: click + arrow-key roving tabindex ---------- */
    function wireTabs(root: HTMLElement) {
      const tabs = Array.from(root.querySelectorAll<HTMLElement>('[role="tab"]'));
      const panels = tabs.map((t) =>
        document.getElementById(t.getAttribute('aria-controls') || ''),
      );

      function select(idx: number, focus = true) {
        tabs.forEach((t, i) => {
          const on = i === idx;
          t.setAttribute('aria-selected', on ? 'true' : 'false');
          t.tabIndex = on ? 0 : -1;
          const panel = panels[i];
          if (panel) panel.hidden = !on;
        });
        if (focus) tabs[idx].focus();
      }

      tabs.forEach((tab, i) => {
        tab.addEventListener('click', () => select(i));
        tab.addEventListener('keydown', (e: KeyboardEvent) => {
          let next = -1;
          if (e.key === 'ArrowRight') next = (i + 1) % tabs.length;
          else if (e.key === 'ArrowLeft') next = (i - 1 + tabs.length) % tabs.length;
          else if (e.key === 'Home') next = 0;
          else if (e.key === 'End') next = tabs.length - 1;
          if (next < 0) return;
          e.preventDefault();
          select(next);
        });
      });
    }

    /* ---------- copy-to-clipboard wiring with styled "Copied!" feedback ---------- */
    function wireCopy(root: HTMLElement) {
      root.querySelectorAll<HTMLButtonElement>('.copy-hash').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const hash = btn.dataset.hash || '';
          try { await navigator.clipboard.writeText(hash); } catch { /* clipboard may be blocked */ }
          const label = btn.querySelector('span');
          if (!label) return;
          const prev = label.textContent;
          label.textContent = 'Copied!';
          btn.style.borderColor = 'var(--ok-edge)';
          btn.style.color = 'var(--accent-bright)';
          setTimeout(() => {
            label.textContent = prev;
            btn.style.borderColor = '';
            btn.style.color = '';
          }, 1400);
        });
      });
    }

    /* ---------- download wiring (FT-PROOF-002) ---------- */
    function wireDownloads(root: HTMLElement) {
      root.querySelectorAll<HTMLButtonElement>('.dl-artifact').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.dl || '';
          const rec = downloads[id];
          if (!rec) return;
          downloadFile(rec.data, rec.filename, rec.mime);
          // Transient "Saved!" feedback, mirroring the copy-hash affordance.
          const label = btn.querySelector('span');
          if (!label) return;
          const prev = label.textContent;
          label.textContent = 'Saved!';
          btn.style.borderColor = 'var(--ok-edge)';
          btn.style.color = 'var(--accent-bright)';
          setTimeout(() => {
            label.textContent = prev;
            btn.style.borderColor = '';
            btn.style.color = '';
          }, 1400);
        });
      });
    }

    async function hydrate() {
      const root = document.getElementById('artifacts-root');
      if (!root) return;

      // First-paint skeleton inside the live tablist shell.
      root.innerHTML = shellHTML(skeletonPanel(), skeletonPanel(), skeletonPanel());
      wireTabs(root);

      // Three independent fetches — each panel degrades on its own.
      let proof = '';
      try {
        const res = await fetchWithTimeout(`${API_BASE}/api/artifacts/proof-pack`);
        if (!res.ok) throw httpError(res);
        const data = await res.json();
        proof = proofHTML(data);
      } catch (err: any) {
        proof = err instanceof TypeError || err?.name === 'AbortError'
          ? offlineHTML(err)
          : emptyHTML(icons.alert, 'Could not load proof pack',
              describeFetchError(err, 'Could not load proof pack. Is the API running?'));
      }

      let cert = '';
      try {
        const res = await fetchWithTimeout(`${API_BASE}/api/artifacts/certificate`);
        if (!res.ok) throw httpError(res);
        const data = await res.json();
        cert = certHTML(data);
      } catch (err: any) {
        cert = err instanceof TypeError || err?.name === 'AbortError'
          ? offlineHTML(err)
          : emptyHTML(icons.alert, 'Could not load certificate',
              describeFetchError(err, 'Could not load certificate. Is the API running?'));
      }

      let reports = '';
      try {
        const res = await fetchWithTimeout(`${API_BASE}/api/artifacts/reports`);
        if (!res.ok) throw httpError(res);
        const data = await res.json();
        reports = reportsHTML(data);
      } catch (err: any) {
        reports = err instanceof TypeError || err?.name === 'AbortError'
          ? offlineHTML(err)
          : emptyHTML(icons.alert, 'Could not load reports',
              describeFetchError(err, 'Could not load reports. Is the API running?'));
      }

      // Replace the skeleton shell with hydrated panels, re-wire interactions.
      root.innerHTML = shellHTML(proof, cert, reports);
      wireTabs(root);
      wireCopy(root);
      wireDownloads(root);
    }

    hydrate();
  </script>
</DashboardLayout>
