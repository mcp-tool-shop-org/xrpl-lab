---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Dashboard" activePage="dashboard">
  <div class="screen-head">
    <h1>Dashboard</h1>
    <p class="lede">Where you are in the workbook, and what the system thinks of your setup.</p>
  </div>
  <div class="screen-inner" id="overview-root">
    <div class="card section"><div class="skeleton" style="height:46px;width:60%"></div></div>
  </div>

  <script>
    import { fetchWithTimeout } from '../../lib/api';
    import { icons, runBadge, healthIcon, esc } from '../../lib/dashboard-ui';

    const API_BASE = 'http://localhost:8321';
    const II = (svg: string) =>
      `<span style="display:inline-flex;width:16px;height:16px;color:var(--text-3)">${svg}</span>`;
    const sk = (h: string, w = '100%') => `<div class="skeleton" style="height:${h};width:${w}"></div>`;

    function skeletonOverview() {
      return `<div class="card section">${sk('46px', '60%')}</div>
        <div class="grid section grid-stats">${Array(4).fill(`<div class="stat">${sk('13px', '50%')}${sk('22px', '70%')}</div>`).join('')}</div>
        <div class="card section">${sk('14px', '30%')}<div class="sk-line skeleton"></div><div class="sk-line skeleton" style="width:80%"></div></div>`;
    }

    function animateProgress() {
      document.querySelectorAll('#overview-root .progress').forEach((p) => {
        const i = p.querySelector('i') as HTMLElement | null;
        if (i) i.style.width = (p.getAttribute('data-pct') || '0') + '%';
      });
    }

    function offlineHTML(err: any) {
      const timeout = err?.name === 'AbortError';
      // FRONTEND-A-005: distinguish a server-side HTTP error (500, etc.) from a
      // truly-offline API. The server IS up if it answered with a status code,
      // so "API is offline" would be misleading.
      const msg = err?.httpStatus
        ? `API error (HTTP ${err.httpStatus}). The server is up but returned an error. Refresh to retry.`
        : timeout
        ? 'Request timed out. The API may be slow or restarting. Refresh to retry.'
        : 'API is offline. Run <code class="mono">xrpl-lab serve</code> in a terminal, then refresh.';
      return `<div class="card"><div class="empty"><span class="empty__ic">${icons.alert}</span>
        <div class="empty__t">Can't reach the API</div><div>${msg}</div></div></div>`;
    }

    function overviewHTML(s: any, doctor: any) {
      const pct = s.modules_total > 0 ? Math.round((s.modules_completed / s.modules_total) * 100) : 0;
      const walletShort = s.wallet_address
        ? s.wallet_address.slice(0, 5) + '…' + s.wallet_address.slice(-4)
        : 'not configured';
      const checks = (doctor && doctor.checks) || [];
      const doctorState = !doctor ? 'warn' : doctor.overall === 'healthy' ? 'ok' : doctor.overall === 'warning' ? 'warn' : 'err';
      const warnCount = checks.filter((c: any) => c.status !== 'pass').length;
      const doctorVal = !doctor ? 'unavailable' : warnCount ? `${warnCount} warning${warnCount > 1 ? 's' : ''}` : 'all clear';
      const lr = s.last_run;
      const tracks = s.track_progress || [];

      const lastRunStat = lr
        ? `<span class="stat__value" style="font-size:15px">${esc(lr.module)} ${runBadge(lr.success ? 'completed' : 'failed')}</span>`
        : `<span class="stat__value muted" style="font-size:15px">No runs yet</span>`;

      const recent = lr
        ? `<div class="row" style="gap:12px">${healthIcon(lr.success ? 'pass' : 'fail')}
             <div><strong>${esc(lr.module)}</strong><div class="muted" style="font-size:13px">${esc(new Date(lr.timestamp).toLocaleString())}</div></div>
             <span style="margin-left:auto">${runBadge(lr.success ? 'completed' : 'failed')}</span></div>`
        : `<p class="muted">No activity yet. Run a module to get started.</p>`;

      const health = !doctor
        ? `<p class="muted">Doctor unavailable — is the API running? Try <code class="mono">xrpl-lab doctor</code>.</p>`
        : `<div class="checks">${checks.map((c: any) => `<div class="check">${healthIcon(c.status)}<div><div class="check__name">${esc(c.name)}</div><div class="check__msg">${esc(c.message)}</div></div></div>`).join('')}</div>`;

      const trackGrid = tracks.length
        ? `<div class="track-grid">${tracks.map((t: any) => {
            const p = t.total > 0 ? Math.round((t.done / t.total) * 100) : 0;
            return `<div class="trk"><div class="trk__head"><span class="trk__name">${esc(t.track)}</span><span class="trk__count">${t.done}/${t.total}</span></div><div class="progress" data-pct="${p}" data-complete="${t.is_complete}"><i></i></div></div>`;
          }).join('')}</div>`
        : `<p class="muted">No track data yet.</p>`;

      return `
      <div class="grid section grid-2-wide items-stretch">
        <div class="card">
          <p class="eyebrow">Overall progress</p>
          <div class="bigprog">
            <div class="bigprog__num">${s.modules_completed}<small>/${s.modules_total}</small></div>
            <div style="flex:1">
              <div class="progress" data-pct="${pct}"><i></i></div>
              <p class="muted" style="margin:9px 0 0;font-size:13.5px">${s.modules_completed} of ${s.modules_total} modules complete · ${pct}% of the workbook</p>
            </div>
          </div>
        </div>
        <a class="qa" href="/xrpl-lab/app/modules/" style="justify-content:center">
          <span class="qa__ic">${icons.play}</span>
          <span class="qa__t">Run a module</span>
          <span class="qa__s">Live testnet or offline dry-run</span>
        </a>
      </div>

      <div class="grid section grid-stats">
        <div class="stat"><span class="stat__label">${II(icons.wallet)} Wallet</span><span class="stat__value"><span class="statdot statdot--${s.wallet_configured ? 'ok' : 'warn'}"></span><span class="mono nowrap" style="font-size:16px">${esc(walletShort)}</span></span></div>
        <div class="stat"><span class="stat__label">${II(icons.net)} Network</span><span class="stat__value"><span class="statdot statdot--${s.network && s.network !== 'unknown' && s.network !== 'mainnet' ? 'ok' : 'warn'}"></span>${esc(s.network || 'unknown')}</span></div>
        <div class="stat"><span class="stat__label">${II(icons.doctor)} Doctor</span><span class="stat__value"><span class="statdot statdot--${doctorState}"></span>${doctorVal}</span></div>
        <div class="stat"><span class="stat__label">${II(icons.play)} Last run</span>${lastRunStat}</div>
      </div>

      <div class="grid section grid-2-wide">
        <div class="card"><p class="eyebrow">Tracks</p>${trackGrid}</div>
        <div class="card"><p class="eyebrow">System health <span class="sr-only">— doctor</span></p>${health}</div>
      </div>

      <div class="grid section grid-2">
        <a class="qa" href="/xrpl-lab/app/artifacts/">
          <span class="qa__ic">${icons.seal}</span>
          <span class="qa__t">Artifacts</span>
          <span class="qa__s">${s.has_proof_pack ? 'Proof pack' : 'No proof pack'} · ${s.has_certificate ? 'certificate' : 'no certificate'} · ${s.report_count} report${s.report_count === 1 ? '' : 's'}</span>
        </a>
        <a class="qa" href="/xrpl-lab/app/verify/">
          <span class="qa__ic">${icons.seal}</span>
          <span class="qa__t">Verify a proof</span>
          <span class="qa__s">Check a pasted proof pack or certificate — offline hash + on-ledger</span>
        </a>
      </div>

      <div class="grid section grid-2">
        <div class="card"><p class="eyebrow">Recent activity</p>${recent}</div>
      </div>`;
    }

    async function hydrate() {
      const root = document.getElementById('overview-root');
      if (!root) return;
      root.innerHTML = skeletonOverview();
      let status: any;
      try {
        const res = await fetchWithTimeout(`${API_BASE}/api/status`);
        if (!res.ok) {
          // FRONTEND-A-005: tag with the status so offlineHTML reports the HTTP
          // error honestly instead of parsing an HTML error body as JSON.
          const e = new Error(`API returned ${res.status}: ${res.statusText}`);
          (e as any).httpStatus = res.status;
          throw e;
        }
        status = await res.json();
      } catch (err) {
        root.innerHTML = offlineHTML(err);
        return;
      }
      let doctor: any = null;
      // Best-effort: skip the doctor card on any non-OK or network error.
      try {
        const dRes = await fetchWithTimeout(`${API_BASE}/api/doctor`);
        if (dRes.ok) doctor = await dRes.json();
      } catch { /* best-effort */ }
      root.innerHTML = overviewHTML(status, doctor);
      requestAnimationFrame(animateProgress);
    }

    hydrate();
  </script>
</DashboardLayout>
