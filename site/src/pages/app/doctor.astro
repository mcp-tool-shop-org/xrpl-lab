---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Doctor" activePage="doctor">
  <div class="screen-head">
    <h1>Doctor</h1>
    <p class="lede">Environment health checks for your XRPL Lab setup.</p>
  </div>

  <div class="screen-inner" id="doctor-root">
    <!-- Re-run control lives in the head row of the body, mirroring the
         segmented filter on the Modules page. It re-fetches /api/doctor and
         re-renders #doctor-results below. -->
    <div class="row section" style="justify-content:flex-end">
      <button id="btn-rerun" class="btn btn--primary" type="button">Re-run checks</button>
    </div>

    <!-- Results region — skeleton on load, then banner + checks, or a graceful
         error/empty state. Swapped wholesale by runDoctor(). -->
    <div id="doctor-results">
      <div class="card section"><div class="skeleton" style="height:46px;width:50%"></div></div>
    </div>
  </div>

  <script>
    import { fetchWithTimeout } from '../../lib/api';
    import { icons, healthIcon, announce, esc } from '../../lib/dashboard-ui';

    // Canonical API base — update in all app pages if port changes
    const API_BASE = 'http://localhost:8321';
    const sk = (h: string, w = '100%') => `<div class="skeleton" style="height:${h};width:${w}"></div>`;

    // Map the doctor overall verdict onto a banner variant + branded copy.
    // The CSS exposes --ok / --stalled / --err banner variants.
    const bannerConfig: Record<string, { variant: string; icon: string; title: string; subtitle: string }> = {
      healthy: { variant: 'ok',      icon: icons.seal,  title: 'All checks passed', subtitle: 'Your environment is ready.' },
      warning: { variant: 'stalled', icon: icons.alert, title: 'Some warnings found', subtitle: 'Review the items below.' },
      error:   { variant: 'err',     icon: icons.alert, title: 'Issues detected', subtitle: 'Fix the failing checks before running modules.' },
    };

    function skeletonResults() {
      return `<div class="card section">${sk('46px', '50%')}</div>
        <div class="card section">${sk('14px', '30%')}<div class="sk-line skeleton"></div><div class="sk-line skeleton" style="width:80%"></div></div>`;
    }

    // Humanized offline/error copy — preserved from the original page, routed
    // through the calm empty state instead of a Tailwind alert box.
    function errorHTML(err: any) {
      let msg = 'Could not run doctor checks. Is the API running?';
      if (err?.name === 'AbortError') {
        msg = 'Doctor checks timed out — check API server is responsive.';
      } else if (err instanceof TypeError) {
        msg = 'Could not reach API server — is it running?';
      }
      return `<div class="card"><div class="empty"><span class="empty__ic">${icons.alert}</span>
        <div class="empty__t">Can't run the doctor</div><div>${esc(msg)}</div></div></div>`;
    }

    function doctorHTML(result: any) {
      const bc = bannerConfig[result.overall] || bannerConfig.error;
      const checks = Array.isArray(result.checks) ? result.checks : [];

      const banner = `<div class="banner banner--${bc.variant} section" role="status">
          <span class="banner__ic">${bc.icon}</span>
          <div><div class="banner__t">${esc(bc.title)}</div><div class="banner__s">${esc(bc.subtitle)}</div></div>
        </div>`;

      const rows = checks.length
        ? `<div class="checks">${checks.map((c: any) =>
            `<div class="check">${healthIcon(c.status)}<div><div class="check__name">${esc(c.name)}</div><div class="check__msg">${esc(c.message)}</div></div></div>`,
          ).join('')}</div>`
        : `<div class="empty"><span class="empty__ic">${icons.inbox}</span>
            <div class="empty__t">No checks reported</div><div>The doctor returned no checks to display.</div></div>`;

      return `${banner}<div class="card section"><p class="eyebrow">Environment checks</p>${rows}</div>`;
    }

    async function runDoctor() {
      const results = document.getElementById('doctor-results');
      if (!results) return;
      results.innerHTML = skeletonResults();

      const btn = document.getElementById('btn-rerun') as HTMLButtonElement | null;
      if (btn) btn.disabled = true;

      try {
        const res = await fetchWithTimeout(`${API_BASE}/api/doctor`);
        const result = await res.json();
        results.innerHTML = doctorHTML(result);
        // Announce the verdict so screen-reader users hear the result of a re-run.
        const verdict = result?.overall === 'healthy' ? 'all checks passed'
          : result?.overall === 'warning' ? 'some warnings found' : 'issues detected';
        announce(`Doctor checks complete — ${verdict}.`);
      } catch (err: any) {
        results.innerHTML = errorHTML(err);
        announce('Doctor checks could not be run.');
      } finally {
        if (btn) btn.disabled = false;
      }
    }

    document.getElementById('btn-rerun')?.addEventListener('click', runDoctor);
    runDoctor();
  </script>
</DashboardLayout>
